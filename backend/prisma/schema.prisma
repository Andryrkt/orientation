generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  VISITOR
  STUDENT
  COACH
  ADMIN
}

enum NiveauMention {
  BTS
  LICENCE
  MASTER
  DOCTORAT
}

enum FavorisableType {
  METIER
  UNIVERSITE
  STAGE
  BOURSE
  COACH
  CENTRE_FORMATION
}

enum CommentaireStatut {
  EN_ATTENTE
  APPROUVE
  REJETE
}

enum TypeQuestion {
  CHOIX_MULTIPLE
  ECHELLE
  TEXTE
}

model Utilisateur {
  id               String    @id @default(uuid())
  nom              String
  prenom           String
  email            String    @unique
  telephone        String?   @unique
  password         String
  role             Role      @default(STUDENT)
  emailVerifiedAt  DateTime?
  refreshTokenHash String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profil               Profil?
  favoris              Favori[]
  blogs                Blog[]
  blogLikes            BlogLike[]
  commentaires         BlogCommentaire[]
  resultatsOrientation ResultatOrientation[]
  coachProfil          Coach?
  avisCoachs           CoachAvis[]
  tickets              Ticket[]
  ticketMessages       TicketMessage[]

  @@map("utilisateurs")
}

model Profil {
  id            String    @id @default(uuid())
  utilisateurId String    @unique
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  dateNaissance DateTime?
  sexe          String?
  region        String?
  niveauEtude   String?
  photo         String?
  bio           String?
  interets      String[]  @default([])
  titreCv       String?
  experiences   Json      @default("[]")
  formations    Json      @default("[]")
  competences   Json      @default("[]")
  langues       Json      @default("[]")

  @@map("profils")
}

model Domaine {
  id          String   @id @default(uuid())
  nom         String
  slug        String   @unique
  description String?
  icone       String?
  ordre       Int      @default(0)
  riasecCodes String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  metiers  Metier[]
  mentions Mention[]
  stages   Stage[]
  bourses  Bourse[]

  @@map("domaines")
}

model Metier {
  id                  String   @id @default(uuid())
  domaineId           String
  domaine             Domaine  @relation(fields: [domaineId], references: [id], onDelete: Restrict)
  nom                 String
  slug                String   @unique
  description         String?
  missions            String[] @default([])
  competences         Json     @default("[]")
  salaireMin          Int?
  salaireMax          Int?
  niveauRequis        String?
  perspectivesEmploi  String?
  riasecCodes         String[] @default([])

  // Section 1 - Identification
  autresAppellations  String[] @default([])
  sousDomaine         String?
  secteursActivite    String[] @default([])
  codeRome            String?

  // Section 2 - Environnement de travail
  environnementTravail String[] @default([])
  environnementAutre   String?

  // Section 3 - Competences
  competencesComportementales String[] @default([])
  languesRequises             String[] @default([])
  niveauLangues                String?

  // Section 4 - Formation et parcours d'acces
  specialiteDiplome     String?
  formationsMadagascar  String[] @default([])
  certifications        String[] @default([])
  autoFormation         String?

  // Section 5 - Conditions de travail et remuneration
  salaireSource       String?
  typeContrat         String[] @default([])
  volumeHoraire       String[] @default([])
  penibilitePhysique  Int?
  penibiliteStress    Int?
  penibiliteRisques   Int?
  avantages           String?

  // Section 6 - Marche de l'emploi a Madagascar
  niveauDemande           String?
  regionsPresence         String[] @default([])
  postesEvolution         String?
  mobiliteInternationale  String?
  tendances               String[] @default([])
  employeurs              String[] @default([])

  // Section 7 - Profil type et personnalite
  traitsPersonnalite       String[] @default([])
  centresInteret           String[] @default([])
  valeursProfessionnelles  String[] @default([])
  profilIntroExtraverti    String?

  // Section 8 - Temoignage professionnel
  temoignagePrenom             String?
  temoignageAnneesExperience   Int?
  temoignageVille              String?
  temoignageSecteurEmployeur   String?
  temoignageCePlait            String?
  temoignageDifficultes        String?
  temoignageConseil            String?
  temoignageCitation           String?
  temoignageAccordPublication  String?

  // Section 9 - Sources et validation
  sources       String[] @default([])
  fiabilite     String?
  observations  String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("metiers")
}

model Universite {
  id          String   @id @default(uuid())
  nom         String
  slug        String   @unique
  description String?
  adresse     String?
  ville       String?
  region      String?
  telephone   String?
  email       String?
  siteWeb     String?
  latitude    Float?
  longitude   Float?
  photos      Json     @default("[]")
  statut      String   @default("public")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mentions Mention[]

  @@map("universites")
}

model Mention {
  id            String        @id @default(uuid())
  universiteId  String
  universite    Universite    @relation(fields: [universiteId], references: [id], onDelete: Cascade)
  domaineId     String
  domaine       Domaine       @relation(fields: [domaineId], references: [id], onDelete: Restrict)
  nom           String
  slug          String        @unique
  description   String?
  niveau        NiveauMention @default(LICENCE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  parcours Parcours[]

  @@map("mentions")
}

model Parcours {
  id               String   @id @default(uuid())
  mentionId        String
  mention          Mention  @relation(fields: [mentionId], references: [id], onDelete: Cascade)
  nom              String
  slug             String   @unique
  description      String?
  duree            String?
  conditionsAcces  String?
  debouches        String?
  fraisAnnuels     Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("parcours")
}

model Stage {
  id                    String    @id @default(uuid())
  titre                 String
  entreprise            String
  description           String?
  domaineId             String?
  domaine               Domaine?  @relation(fields: [domaineId], references: [id], onDelete: SetNull)
  duree                 String?
  dateDebut             DateTime?
  dateLimiteCandidature DateTime?
  region                String?
  niveauEtude           String?
  remuneration          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("stages")
}

model Bourse {
  id          String    @id @default(uuid())
  nom         String
  organisme   String
  pays        String?
  domaineId   String?
  domaine     Domaine?  @relation(fields: [domaineId], references: [id], onDelete: SetNull)
  niveauEtude String?
  montant     String?
  dateLimite  DateTime?
  conditions  String?
  lien        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("bourses")
}

model Blog {
  id          String    @id @default(uuid())
  titre       String
  slug        String    @unique
  contenu     String
  image       String?
  categorie   String?
  auteurId    String
  auteur      Utilisateur @relation(fields: [auteurId], references: [id], onDelete: Restrict)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  likes        BlogLike[]
  commentaires BlogCommentaire[]

  @@map("blogs")
}

model BlogLike {
  id            String      @id @default(uuid())
  blogId        String
  blog          Blog        @relation(fields: [blogId], references: [id], onDelete: Cascade)
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([blogId, utilisateurId])
  @@map("blog_likes")
}

model BlogCommentaire {
  id            String            @id @default(uuid())
  blogId        String
  blog          Blog              @relation(fields: [blogId], references: [id], onDelete: Cascade)
  utilisateurId String
  utilisateur   Utilisateur       @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  contenu       String
  statut        CommentaireStatut @default(EN_ATTENTE)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("blog_commentaires")
}

model Questionnaire {
  id          String   @id @default(uuid())
  titre       String
  description String?
  type        String?  @default("RIASEC")
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions Question[]
  resultats ResultatOrientation[]

  @@map("questionnaires")
}

model Question {
  id              String        @id @default(uuid())
  questionnaireId String
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  texte           String
  type            TypeQuestion  @default(CHOIX_MULTIPLE)
  ordre           Int           @default(0)
  scoreDimensions Json          @default("{}")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  reponses Reponse[]

  @@map("questions")
}

model Reponse {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  texte      String
  score      Json     @default("{}")
  ordre      Int      @default(0)

  @@map("reponses")
}

model ResultatOrientation {
  id                  String        @id @default(uuid())
  utilisateurId       String
  utilisateur         Utilisateur   @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  questionnaireId     String
  questionnaire       Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Restrict)
  scores              Json
  profilDominant      String?
  domainesRecommandes Json          @default("[]")
  metiersRecommandes  Json          @default("[]")
  reponses            Json          @default("[]")
  createdAt           DateTime      @default(now())

  @@map("resultats_orientation")
}

model CentreFormation {
  id        String   @id @default(uuid())
  nom       String
  slug      String   @unique
  adresse   String?
  ville     String?
  region    String?
  contact   String?
  siteWeb   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("centres_formation")
}

model Coach {
  id              String       @id @default(uuid())
  utilisateurId   String?      @unique
  utilisateur     Utilisateur? @relation(fields: [utilisateurId], references: [id], onDelete: SetNull)
  nom             String
  prenom          String
  email           String?
  telephone       String?
  photo           String?
  bio             String?
  specialites     String[]     @default([])
  experience      String?
  disponibilites  String?
  visible         Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  avis CoachAvis[]

  @@map("coachs")
}

model CoachAvis {
  id            String      @id @default(uuid())
  coachId       String
  coach         Coach       @relation(fields: [coachId], references: [id], onDelete: Cascade)
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  note          Int
  commentaire   String?
  createdAt     DateTime    @default(now())

  @@unique([coachId, utilisateurId])
  @@map("coach_avis")
}

model Favori {
  id            String          @id @default(uuid())
  utilisateurId String
  utilisateur   Utilisateur     @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  type          FavorisableType
  entityId      String
  createdAt     DateTime        @default(now())

  @@unique([utilisateurId, type, entityId])
  @@map("favoris")
}

enum TicketStatut {
  OUVERT
  EN_COURS
  RESOLU
  FERME
}

enum TicketPriorite {
  BASSE
  MOYENNE
  HAUTE
}

model Ticket {
  id            String          @id @default(uuid())
  sujet         String
  description   String?
  statut        TicketStatut    @default(OUVERT)
  priorite      TicketPriorite  @default(MOYENNE)
  categorie     String          @default("AUTRE")
  utilisateurId String
  utilisateur   Utilisateur     @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  messages      TicketMessage[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("tickets")
}

model TicketMessage {
  id            String      @id @default(uuid())
  ticketId      String
  ticket        Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  auteurId      String
  auteur        Utilisateur @relation(fields: [auteurId], references: [id], onDelete: Cascade)
  message       String
  createdAt     DateTime    @default(now())

  @@map("ticket_messages")
}
